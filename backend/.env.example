# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/pulse-analytics
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/pulse-analytics
MONGO_URI=mongodb://127.0.0.1:27017/pulse-analytics

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Comma separated list of origins allowed to call the API (your frontend URL)
CLIENT_ORIGIN=http://localhost:5173
